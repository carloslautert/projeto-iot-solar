# Token do device no TagoIO.
# Nunca coloque o token real no GitHub.
TAGOIO_TOKEN=cole_aqui_o_token_do_device

# Endpoint HTTP do TagoIO usado no projeto.
TAGOIO_HTTP_URL=https://api.eu-w1.tago.io/data

# Local monitorado: Florianópolis, SC.
LATITUDE=-27.5954
LONGITUDE=-48.5480
TIMEZONE=America/Sao_Paulo

# Parâmetros do sistema fotovoltaico simulado.
AREA_PAINEL_M2=10
EFICIENCIA_PAINEL=0.20

# Intervalo entre coletas.
# 120 segundos para demonstração em vídeo; 1200 segundos para uso normal a cada 20 minutos.
INTERVALO_SEGUNDOS=120
